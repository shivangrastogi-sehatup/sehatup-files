{% comment %} snippets/otp-verification-modal.liquid {% endcomment %}
<style>
  .otp-screen {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.45);
    justify-content: center;
    align-items: center;
    z-index: 99999;
  }
  .otp-box {
    background: #fff;
    border-radius: 12px;
    padding: 25px 30px;
    width: 90%;
    max-width: 360px;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.15);
    position: relative;
    text-align: center;
    font-family: "Segoe UI", sans-serif;
  }
  .otp-close {
    position: absolute;
    top: 12px;
    right: 16px;
    font-size: 20px;
    cursor: pointer;
    color: #888;
  }
  .otp-box h3 {
    margin-bottom: 10px;
    font-size: 22px;
    font-weight: bold;
    color: #333;
  }
  .otp-box p {
    font-size: 15px;
    color: #555;
    margin-bottom: 10px;
  }
  .otp-input-group {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin: 15px 0;
  }
  .otp-input-group input {
    width: 40px;
    height: 45px;
    text-align: center;
    font-size: 20px;
    border: 1px solid #ccc;
    border-radius: 6px;
    outline: none;
    transition: 0.2s;
  }
  .otp-input-group input:focus {
    border-color: #007bff;
    box-shadow: 0 0 3px #007bff88;
  }
  .otp-box .verify-btn,
  .otp-box button {
    background: #007bff;
    color: white;
    border: none;
    padding: 12px;
    font-size: 15px;
    border-radius: 8px;
    cursor: pointer;
    width: 100%;
    transition: background 0.3s ease;
    font-weight: bold;
    margin-top: 15px;
  }
  .otp-box .verify-btn:hover,
  .otp-box button:hover {
    background: #0056b3;
  }
  .resend-text {
    font-size: 13px;
    color: #666;
    margin-bottom: 10px;
  }
  #otp-phone {
    font-size: 16px;
    border: 1px solid #ccc;
    border-radius: 8px;
    padding: 12px;
    width: 100%;
    box-sizing: border-box;
    margin-bottom: 10px;
  }
  #otp-toast {
    font-size: 14px;
    font-weight: 500;
    margin-top: 10px;
    color: green;
    display: none;
  }


  .otp-footer {
    background: #f8fff9;
    border-top: 1px solid #e3e3e3;
    text-align: center;
    padding: 14px 18px;
    margin-top: 15px;
    border-radius: 0 0 12px 12px;
    font-size: 13px;
  }
  .footer-container {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    gap: 10px;
    max-width: 100%;
    margin: 0 auto;
    flex-wrap: nowrap;
  }
  .footer-icon {
    font-size: 20px;
    color: #4caf50;
    flex-shrink: 0;
  }
  .footer-text {
    text-align: left;
    font-size: 13px;
    color: #444;
    line-height: 1.5;
    flex: 1;
  }
  .footer-text strong {
    display: block;
    font-size: 14px;
    margin-bottom: 4px;
    color: #2e7d32;
  }
  .footer-text a {
    color: #007bff;
    text-decoration: none;
  }
  .footer-text a:hover {
    text-decoration: underline;
  }

  @media (max-width: 480px) {
    .footer-container {
      flex-direction: column;
      text-align: center;
      gap: 6px;
    }
    .footer-text {
      text-align: center;
      font-size: 12px;
    }
    .footer-text strong {
      font-size: 13px;
    }
  }
</style>

<div id="otp-modal" class="otp-screen">
  <div class="otp-box">
    <span class="otp-close" data-action="close-otp">×</span> 
    
    <div id="otp-step-1">
      <h3>Confirm your number</h3>
      <p>We'll send a WhatsApp report after verification.</p>
      <input type="tel" id="otp-phone" maxlength="10" placeholder="Enter phone number" inputmode="numeric" pattern="\d*">
      <small id="phone-warning" style="color: red; display: none;">Phone number must be exactly 10 digits.</small>
      <button data-action="send-otp">Send OTP</button>
    </div>
    
    <div id="otp-step-2" style="display: none;">
      <h3>Verify with OTP</h3>
      <p>Please enter the OTP sent to your phone.</p>
      <div class="otp-input-group">
        <input type="tel" class="otp-input" pattern="\d*" inputmode="numeric" maxlength="1">
        <input type="tel" class="otp-input" pattern="\d*" inputmode="numeric" maxlength="1">
        <input type="tel" class="otp-input" pattern="\d*" inputmode="numeric" maxlength="1">
        <input type="tel" class="otp-input" pattern="\d*" inputmode="numeric" maxlength="1">
        <input type="tel" class="otp-input" pattern="\d*" inputmode="numeric" maxlength="1">
        <input type="tel" class="otp-input" pattern="\d*" inputmode="numeric" maxlength="1">
      </div>
      <p class="resend-text" id="resend-text">
        Didn't receive the OTP?
        <span id="resend-link" data-action="resend-otp" style="color: #007bff; ... display: none;">
          RESEND OTP
        </span>
        <span id="otp-timer" style="margin-left: 5px; color: #888;"></span>
      </p>
      <button data-action="verify-otp">Verify</button>
    </div>
    
    <div id="otp-toast"></div>
    <div class="otp-footer">
      </div>
  </div>
</div>