{% comment %} loader-overlay.liquid {% endcomment %}
<style>
    #loader {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: #ffffff;
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 10000;
        flex-direction: column;
        transition: opacity 0.8s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .loader-content {
        text-align: center;
        animation: fadeIn 1s ease-in-out;
    }

    .bg-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: url("https://cdn.shopify.com/s/files/1/0924/5687/8383/files/questionnaire_blue.webp?v=1775193815") no-repeat center center;
        background-size: cover;
        z-index: -1;
        opacity: 0.5;
    }

    .fade-out {
        opacity: 0 !important;
        pointer-events: none;
    }

    .fade-in-content {
        animation: fadeInContent 1.2s cubic-bezier(0.4, 0, 0.2, 1) forwards;
    }

    @keyframes fadeInContent {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }

</style>

<!-- Loader Overlay -->
<div id="loader">
  <div class="loader-content">
    <img
      src="https://cdn.shopify.com/s/files/1/0924/5687/8383/files/GIF.gif?v=1745393486"
      alt="Loading..."
      style="width: 100px; height: 100px"
    >
    <p style="font-size: 18px; font-weight: bold">Calculating your personalized health report... 😊</p>
    <p style="font-size: 16px">Please wait a moment while we analyze your responses.</p>
  </div>
</div>

<!-- Background Overlay -->
<div class="bg-overlay"></div>

<script>
    function showLoader() {
        const loader = document.getElementById("loader");
        loader.style.display = "flex";
        document.body.style.overflow = "hidden";
        setTimeout(hideLoader, 15000);
    }

    function hideLoader() {
        const loader = document.getElementById("loader");
        if (!loader) return;
        window.scrollTo(0, 0);
        loader.classList.add('fade-out');
        setTimeout(() => {
            loader.style.display = "none";
            document.body.style.overflow = "auto";
        }, 800);
    }
</script>
