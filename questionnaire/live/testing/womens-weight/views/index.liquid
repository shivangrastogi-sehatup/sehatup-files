                      </div>
                      <div class="risk-level-badge" id="risk-level-badge"></div>
                  </div>
              </div>
              <span class="patient-id" id="patient-id"></span>

              
              <!-- NEW PREMIUM RISK INTELLIGENCE SECTION -->
              <div class="future-risk-section">
                  <div class="risk-intelligence-header">
                      <h2>Potential Health Risks If Ignored</h2>
                      <p class="risk-intelligence-description">If left untreated, these conditions may gradually impact your health and wellbeing.</p>
                  </div>

                  <div id="future-risk-tags" class="risk-cards-grid">
