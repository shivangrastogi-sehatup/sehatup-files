<!-- Version 3.6.5 - Categorical Separation (EN/HI Divided Flow) -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    if (typeof QuestionnaireEngine !== 'undefined') {
       console.log("NUCLEAR OVERRIDE v3.6.5: Categorical Separation Initialized");
       
       QuestionnaireEngine.prototype.renderResults = function() {
          const lang = localStorage.getItem(`selected_lang_${this.config.id}`) || this.currentLanguage || 'en';
          this.currentLanguage = lang; 
          this.version = "3.6.5 (Divided Flow)";
          
          const langData = this.uiTranslations[lang];
          if (!langData) return;

          // 1. Force Global Re-calculation
          if (typeof this.config.resultRules === 'function') {
               this.state.results = this.config.resultRules(this.state.healthScore, this.state.allAnswers, this.config, this.state.userInfo);
          }

          // 2. Clear & Reset Static UI
          this.updateStaticUI();
          this.updateLanguageToggle();

          // 3. DIVIDED FLOW: English Baseline vs Hindi Transformation
          const rawName = this.state.userInfo.name || "Patient";
          let displayName = rawName;
          let displayIssueTitle = this.state.results.issueTitle;
          let displayConditionHTML = this.state.results.conditionTextHTML;
          let riskLabel = this.state.results.riskLevel || 'high-risk';
          let currency = "Rs.";

          if (lang === 'hi') {
              // HINDI TRANSFORMATION
              const nameMap = { 'shivang': 'शिवांग', 'shivam': 'शिवम', 'rohit': 'रोहित' };
              displayName = nameMap[rawName.toLowerCase().trim()] || rawName;
              displayIssueTitle = this.state.results.issueTitleHi || displayIssueTitle;
              displayConditionHTML = this.state.results.conditionTextHTMLHi || displayConditionHTML;
              riskLabel = langData[riskLabel] || riskLabel;
              currency = "रु.";
          } else {
              // ENGLISH BASELINE (Pure reset)
              const reverseMap = { 'शिवांग': 'Shivang', 'शिवम': 'Shivam' };
              displayName = reverseMap[rawName] || rawName;
              currency = "Rs.";
          }

          // 4. Apply Updates Categorically
          const userNameEl = document.getElementById('user-name');
          if (userNameEl) userNameEl.innerText = displayName;

          if (this.state.userInfo.dob) {
              const dob = new Date(this.state.userInfo.dob);
              const today = new Date();
              let age = today.getFullYear() - dob.getFullYear();
              const m = today.getMonth() - dob.getMonth();
              if (m < 0 || (m === 0 && today.getDate() < dob.getDate())) {
                  age--;
              }
              const userAgeEl = document.getElementById('user-age');
              if (userAgeEl) userAgeEl.innerText = age;
          }

          const userConcernEl = document.getElementById('user-concern');
          const issueHeaderEl = document.getElementById('issue-header');
          if (userConcernEl) userConcernEl.innerText = displayIssueTitle;
          if (issueHeaderEl) issueHeaderEl.innerText = displayIssueTitle;

          const conditionTextEl = document.getElementById('condition-text');
          const conditionDetailsEl = document.getElementById('condition-details');
          if (conditionTextEl) conditionTextEl.innerHTML = displayConditionHTML;
          if (conditionDetailsEl) conditionDetailsEl.innerHTML = displayConditionHTML;

          const riskLevelEl = document.getElementById('risk-level');
          if (riskLevelEl) {
              riskLevelEl.innerText = langData[riskLabel] || riskLabel;
          }

          const totalAmountEl = document.getElementById('total-amount');
          if (totalAmountEl) {
              const totalVal = totalAmountEl.textContent.match(/\d+/);
              if (totalVal) totalAmountEl.textContent = currency + totalVal[0];
          }

          // Update Future Risks
          const riskContainer = document.getElementById('future-risk-tags');
          if (riskContainer && this.state.results.futureRisks) {
              riskContainer.innerHTML = this.state.results.futureRisks.map(risk => {
                  const text = (lang === 'hi' && risk.hi) ? risk.hi : (risk.en || risk.text || risk);
                  return `<div class="risk-tag">${text}</div>`;
              }).join('');
          }
       };
    }
  });
</script>
