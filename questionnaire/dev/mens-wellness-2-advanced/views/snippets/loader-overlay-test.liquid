{% comment %} loader-overlay.liquid {% endcomment %}
<style>
    #loader {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: #ffffff;
        display: none;
        justify-content: center;
        align-items: center;
        z-index: 10000;
        flex-direction: column;
    }

    .loader-content {
        text-align: center;
        animation: fadeIn 1s ease-in-out;
    }

    .bg-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: url("https://cdn.shopify.com/s/files/1/0924/5687/8383/files/questionnaire_blue.jpg?v=1742991013") no-repeat center center;
        background-size: cover;
        z-index: -1;
        opacity: 0.5;
    }

</style>

<!-- Loader Overlay -->
<div id="loader">
  <div class="loader-content">
    <img
      src="https://cdn.shopify.com/s/files/1/0924/5687/8383/files/GIF.gif?v=1745393486"
      alt="Loading..."
      style="width: 100px; height: 100px"
    >
    <p data-i18n="calculating-health-report" style="font-size: 18px; font-weight: bold">Calculating your personalized health report... 😊</p>
    <p data-i18n="wait-moment" style="font-size: 16px">Please wait a moment while we analyze your responses.</p>
  </div>
</div>

<!-- Background Overlay -->
<div class="bg-overlay"></div>

<script>
    function showLoader() {
        const loader = document.getElementById("loader");
        
        // Push language update to loader content if engine is ready
        if (window.questionnaireEngine && typeof window.questionnaireEngine.updateStaticUI === 'function') {
            window.questionnaireEngine.updateStaticUI(loader);
        }

        loader.style.display = "flex";
        document.body.style.overflow = "hidden";
        setTimeout(hideLoader, 15000);
    }

    function hideLoader() {
        const loader = document.getElementById("loader");
        loader.style.display = "none";
        document.body.style.overflow = "auto";
    }
</script>
